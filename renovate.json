{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^isponsorblocktv/config\\.yaml$/",
        "/^isponsorblocktv-setup/config\\.yaml$/"
      ],
      "matchStrings": ["version: \"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "iSponsorBlockTV",
      "datasourceTemplate": "pypi"
    }
  ]
}
