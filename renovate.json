{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^isponsorblocktv/config\\.yaml$", "^isponsorblocktv-setup/config\\.yaml$"],
      "matchStrings": ["version: \"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "iSponsorBlockTV",
      "datasourceTemplate": "pypi"
    }
  ]
}
